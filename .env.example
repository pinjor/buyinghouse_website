# Local docker-compose MariaDB root password only — cPanel deployments set DATABASE_URL
# per service directly instead (see the deployment runbook), this var isn't used there.
MYSQL_ROOT_PASSWORD=root
# Required — services refuse to start without these set to a real, non-default secret.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
# Required — shared secret between gateway and catalog-service/order-service so those
# services can trust the identity headers gateway sets, even if they end up independently
# network-reachable (e.g. each service getting its own public URL on cPanel).
INTERNAL_SERVICE_SECRET=change-me-internal
# Optional — comma-separated list of allowed browser origins for the gateway. Leave blank in
# local/docker dev; set to your production domain(s) once deployed (e.g. https://novaterra.apparel).
CORS_ORIGIN=
# Required for card checkout to work; leave blank to disable card payments (wire invoicing still works).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=orders@novaterra.apparel
ADMIN_EMAIL=admin@novaterra.com
ADMIN_PASSWORD=change-me-admin-password
